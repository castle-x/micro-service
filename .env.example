# 环境变量模板 — 复制为 .env 后填入真实值，切勿提交真实凭据

# MongoDB
MONGO_URI=mongodb://localhost:27017/platform

# Redis
REDIS_ADDR=localhost:6379

# JWT（生产环境必须随机生成，至少 32 字节）
JWT_SECRET=change-me-to-a-random-32-byte-string!!

# Google OAuth2（在 https://console.cloud.google.com/apis/credentials 创建）
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URL=http://localhost:38080/api/v1/auth/google/callback

# 支付宝 OAuth2
# ALIPAY_ENV=sandbox 走沙箱，其他值（production）走正式
ALIPAY_ENV=sandbox

# 正式环境
ALIPAY_APP_ID=your-production-app-id
ALIPAY_PRIVATE_KEY=your-production-rsa2-private-key-pkcs8
ALIPAY_PUB_KEY=your-production-alipay-public-key
ALIPAY_REDIRECT_URL=https://your-domain.com/api/v1/auth/alipay/callback
ALIPAY_GATEWAY_URL=https://openapi.alipay.com/gateway.do
ALIPAY_AUTH_URL=https://openauth.alipay.com/oauth2/publicAppAuthorize.htm

# 沙箱环境（命名与正式一致，加 SANDBOX_ 前缀）
ALIPAY_SANDBOX_APP_ID=your-sandbox-app-id
ALIPAY_SANDBOX_PRIVATE_KEY=your-sandbox-rsa2-private-key-pkcs8
ALIPAY_SANDBOX_PUB_KEY=your-sandbox-alipay-public-key
ALIPAY_SANDBOX_REDIRECT_URL=http://localhost:38080/api/v1/auth/alipay/callback
ALIPAY_SANDBOX_GATEWAY_URL=https://openapi-sandbox.dl.alipaydev.com/gateway.do
ALIPAY_SANDBOX_AUTH_URL=https://openauth-sandbox.dl.alipaydev.com/oauth2/publicAppAuthorize.htm

# 服务注册与发现（默认必走 etcd）
REGISTRY_TYPE=etcd
DISCOVERY_TYPE=etcd
REGISTRY_PREFIX=micro-service
DISCOVERY_PREFIX=micro-service
ETCD_ENDPOINT=127.0.0.1:2379
EDGE_REGISTRY_ADDR=127.0.0.1:38080
IDP_REGISTRY_ADDR=127.0.0.1:38081
IAM_REGISTRY_ADDR=127.0.0.1:38082
MODEL_REGISTRY_ADDR=127.0.0.1:38083

# OpenTelemetry / OpenObserve（开发阶段默认开启；make dev-start 会自动启动 obs-up）
OTEL_ENABLED=true
OTEL_ENDPOINT=localhost:4317
OTEL_PROTOCOL=grpc
OTEL_ENVIRONMENT=local
OTEL_SERVICE_VERSION=dev
OTEL_SAMPLE_RATIO=1
OTEL_INSECURE=true
OTEL_STRICT=false

# OpenObserve 本地默认账号；真实密码如有调整请同步 OPENOBSERVE_AUTH_HEADER
OPENOBSERVE_URL=http://localhost:5080
OPENOBSERVE_ORG=default
OPENOBSERVE_STREAM=default
OPENOBSERVE_ROOT_USER_EMAIL=root@example.com
OPENOBSERVE_ROOT_USER_PASSWORD=Complexpass123
OPENOBSERVE_AUTH_HEADER=Basic cm9vdEBleGFtcGxlLmNvbTpDb21wbGV4cGFzczEyMw==

# Asset OSS storage — dev（本地/集成测试默认使用）
# AS-04 实现后 asset service 会通过 deployments/config/asset.yaml 引用这些环境变量。
ASSET_STORAGE_PROVIDER=aliyun_oss
ASSET_STORAGE_OBJECT_KEY_PREFIX=assets-test
ASSET_UPLOAD_URL_TTL_SECONDS=900
ASSET_DOWNLOAD_URL_TTL_SECONDS=900
ASSET_STORAGE_MAX_UPLOAD_SIZE_BYTES=20971520
ASSET_OSS_INTEGRATION=0
ASSET_BASE_URL=http://localhost:38080
ASSET_ADMIN_EMAIL=admin@platform.com
ASSET_ADMIN_PASSWORD=Admin@1234
ALIYUN_OSS_REGION=cn-shanghai
ALIYUN_OSS_ENDPOINT=https://oss-cn-shanghai.aliyuncs.com
ALIYUN_OSS_BUCKET=castle-x-asset-dev
ALIYUN_OSS_ACCESS_KEY_ID=your-dev-ram-access-key-id
ALIYUN_OSS_ACCESS_KEY_SECRET=your-dev-ram-access-key-secret
ALIYUN_OSS_SECURITY_TOKEN=
ALIYUN_OSS_PUBLIC_BASE_URL=
ALIYUN_OSS_CDN_BASE_URL=

# Asset OSS storage — prod（上线时复制到部署环境，不要在本地同时启用两套同名变量）
