# 环境变量模板 — 复制为 .env 后填入真实值，切勿提交真实凭据

# MongoDB
MONGO_URI=mongodb://localhost:27017/platform

# Redis
REDIS_ADDR=localhost:6379

# JWT（生产环境必须随机生成，至少 32 字节）
JWT_SECRET=change-me-to-a-random-32-byte-string!!

# Google OAuth2（在 https://console.cloud.google.com/apis/credentials 创建）
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URL=http://localhost:38080/api/v1/auth/google/callback

# 支付宝 OAuth2（在 https://open.alipay.com 创建应用）
ALIPAY_APP_ID=your-alipay-app-id
ALIPAY_PRIVATE_KEY=your-app-rsa2-private-key-pkcs8-base64
ALIPAY_PUB_KEY=your-alipay-public-key-base64
ALIPAY_REDIRECT_URL=http://localhost:38080/api/v1/auth/alipay/callback
# 沙箱环境：
ALIPAY_GATEWAY_URL=https://openapi-sandbox.dl.alipaydev.com/gateway.do
ALIPAY_AUTH_URL=https://openauth-sandbox.dl.alipaydev.com/oauth2/publicAppAuthorize.htm
# 生产环境（替换上面两行）：
# ALIPAY_GATEWAY_URL=https://openapi.alipay.com/gateway.do
# ALIPAY_AUTH_URL=https://openauth.alipay.com/oauth2/publicAppAuthorize.htm

# 服务地址覆盖（可选）
IDP_ADDR=127.0.0.1:38081
IAM_ADDR=127.0.0.1:38082
