# 环境变量模板 — 复制为 .env 后填入真实值，切勿提交真实凭据

# MongoDB
MONGO_URI=mongodb://localhost:27017/platform

# Redis
REDIS_ADDR=localhost:6379

# JWT（生产环境必须随机生成，至少 32 字节）
JWT_SECRET=change-me-to-a-random-32-byte-string!!

# Google OAuth2（在 https://console.cloud.google.com/apis/credentials 创建）
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URL=http://localhost:38080/api/v1/auth/google/callback

# 支付宝 OAuth2
# ALIPAY_ENV=sandbox 走沙箱，其他值（production）走正式
ALIPAY_ENV=sandbox

# 正式环境
ALIPAY_APP_ID=your-production-app-id
ALIPAY_PRIVATE_KEY=your-production-rsa2-private-key-pkcs8
ALIPAY_PUB_KEY=your-production-alipay-public-key
ALIPAY_REDIRECT_URL=https://your-domain.com/api/v1/auth/alipay/callback
ALIPAY_GATEWAY_URL=https://openapi.alipay.com/gateway.do
ALIPAY_AUTH_URL=https://openauth.alipay.com/oauth2/publicAppAuthorize.htm

# 沙箱环境（命名与正式一致，加 SANDBOX_ 前缀）
ALIPAY_SANDBOX_APP_ID=your-sandbox-app-id
ALIPAY_SANDBOX_PRIVATE_KEY=your-sandbox-rsa2-private-key-pkcs8
ALIPAY_SANDBOX_PUB_KEY=your-sandbox-alipay-public-key
ALIPAY_SANDBOX_REDIRECT_URL=http://localhost:38080/api/v1/auth/alipay/callback
ALIPAY_SANDBOX_GATEWAY_URL=https://openapi-sandbox.dl.alipaydev.com/gateway.do
ALIPAY_SANDBOX_AUTH_URL=https://openauth-sandbox.dl.alipaydev.com/oauth2/publicAppAuthorize.htm

# 服务地址覆盖（可选）
IDP_ADDR=127.0.0.1:38081
IAM_ADDR=127.0.0.1:38082
