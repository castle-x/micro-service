# Deprecated root env template.
#
# The project now uses split local environment files under deployments/env/.
# Copy and fill these files instead:
#
#   cp deployments/env/infra.env.example deployments/env/infra.env
#   cp deployments/env/observability.env.example deployments/env/observability.env
#   cp deployments/env/asset.env.example deployments/env/asset.env
#   cp deployments/env/model.env.example deployments/env/model.env
#   cp deployments/env/secrets.env.example deployments/env/secrets.env
#   cp deployments/env/overrides.env.example deployments/env/overrides.env
#
# Root .env is still loaded only for legacy migration compatibility and has the
# lowest priority. New values should not be added here.
