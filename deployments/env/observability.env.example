# OpenTelemetry and OpenObserve local defaults.

OTEL_ENABLED=true
OTEL_ENDPOINT=localhost:4317
OTEL_PROTOCOL=grpc
OTEL_ENVIRONMENT=local
OTEL_SERVICE_VERSION=dev
OTEL_SAMPLE_RATIO=1
OTEL_INSECURE=true
OTEL_STRICT=false

OPENOBSERVE_URL=http://localhost:5080
OPENOBSERVE_ORG=default
OPENOBSERVE_STREAM=default
OPENOBSERVE_ROOT_USER_EMAIL=root@example.com
OPENOBSERVE_ROOT_USER_PASSWORD=Complexpass123
OPENOBSERVE_AUTH_HEADER="Basic cm9vdEBleGFtcGxlLmNvbTpDb21wbGV4cGFzczEyMw=="
